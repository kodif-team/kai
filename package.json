{
  "name": "kai-action",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --format=cjs",
    "test:router": "esbuild tests/router.test.ts --bundle --platform=node --target=node20 --format=cjs --outfile=/tmp/kai-router.test.cjs && esbuild tests/templates.test.ts --bundle --platform=node --target=node20 --format=cjs --outfile=/tmp/kai-templates.test.cjs && node --test /tmp/kai-router.test.cjs /tmp/kai-templates.test.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@anthropic-ai/sdk": "^0.89.0",
    "@octokit/rest": "^21.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}
