{
  "name": "kai-action",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --format=cjs",
    "build:test-modules": "node scripts/build-test-modules.mjs",
    "test:router": "npm run build && npm run build:test-modules && node --experimental-strip-types --test tests/router.test.ts tests/templates.test.ts tests/router-local-llm.test.ts tests/audit.test.ts tests/repo-policy.test.ts",
    "test:router:live": "npm run build && node --experimental-strip-types --test tests/router-live-llm.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@anthropic-ai/sdk": "^0.89.0",
    "@octokit/rest": "^21.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}
